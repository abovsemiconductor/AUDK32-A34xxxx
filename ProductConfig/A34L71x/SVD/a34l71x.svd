          <addressOffset>0x0054</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>ECCED</name>
              <description>ECC error data (Offset: 0x0E00_0000)</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>ECCEPARITY</name>
          <description>Data Flash ECC Error Parity Register</description>
          <addressOffset>0x0058</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>ECCEP</name>
              <description>ECC error parity</description>
              <bitOffset>0</bitOffset>
              <bitWidth>7</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>HSICMU</name>
      <groupName>HSICMU</groupName>
      <description>HIGH-SPEED INTERNAL OSC CLOCK MANAGEMENT UNIT</description>
      <baseAddress>0x40004000</baseAddress>
      <addressBlock>
        <offset>0x00000000</offset>
        <size>0x0020</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <name>CR</name>
          <description>High Speed Internal OSC Clock Management Unit Control Register</description>
          <addressOffset>0x0000</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00001000</resetValue>
          <fields>
            <field>
              <name>SET_TRIMVALUE</name>
              <description>The value of the trim register is applied to the high speed internal OSC 0: No Action 1: The value of the trim register is applied to the high speed internal OSC</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SYNC_START</name>
              <description>Start synchronized timer 0: No Action 1: Start synchronized timer</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SET_TIMER</name>
              <description>The value in the Reload register is written to the FERRCNT 0: No Action 1: The value in the Reload register is written to the Frequency Error Rate Counter</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SW_SYNC</name>
              <description>Generate Software SYNC event 0: No Action 1: A software SYNC event is generate</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>AUTOTRIM_EN</name>
              <description>Auto Trim Enable 0: Auto trimming disable 1: Auto trimming enable *This bit enables the automatic hardware adjustment of TRIM bits according to the measured frequency error between two SYNC events. If this bit is set, the TRIM bits are read-only. The TRIM value can be adjusted by hardware by one or two ot three steps at a time, depending on the measured frequency error value. ** Before setting this bit, you must load the trim value into the trim register and set SET_TRIMVALUE BIT to 1.</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>HSICMU_EN</name>
              <description>HSICMU Peripheral block Enable 0: disable 1: enable</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>CFG</name>
          <description>High Speed Internal OSC Clock Management Unit Config Register</description>
          <addressOffset>0x0004</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x0000FFFF</resetValue>
          <fields>
            <field>
              <name>SESYNCPOL</name>
              <description>This bit is set and cleared by software to select the input polarity for the SYNC signal source. 00: Both edge. 01: Rising edge. 10: Falling edge. 11: RESERVED.</description>
              <bitOffset>30</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SYNCSRC</name>
              <description>SYNC Signal Source Selection These bits are set and cleared by software to select the SYNC signal source. 00: Capture Data Update when SOF is successfully received. 01: Capture Data Update when SOF is successfully received and also even when SOF is missed. 10: SOSC CLK. 11: GPIO.</description>
              <bitOffset>28</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>AC_EN</name>
              <description>Auto Clear Enable 0: No Action 1: Auto Clear Enable</description>
              <bitOffset>27</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SYNCDIV</name>
              <description>SYNC Divider These bits are set and cleared by software to control the division factor of the SYNC signal. 000: SYNC not divided (default) 001: SYNC divided by 2 010: SYNC divided by 4 011: SYNC divided by 8 100: SYNC divided by 16 101: SYNC divided by 32 110: SYNC divided by 64 111: SYNC divided by 128</description>
              <bitOffset>24</bitOffset>
              <bitWidth>3</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>RELOAD</name>
              <description>Sync Timer Reload Value RELOAD is the value to be loaded in the Synctimer with each SYNC event.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>ISR</name>
          <description>High Speed Internal OSC Clock Management Unit Interrupt &amp; Status Register</description>
          <addressOffset>0x0008</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>FECDIR</name>
              <description>Frequency Error Capture Direction 0: count under reload 1: count over reload</description>
              <bitOffset>15</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>SYNC_FLAG</name>
              <description>Sync Signal Flag 0: None 1: Updated HSICMU_CAP register with input sync signal</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>TRIMOVF</name>
              <description>Trim Value Over flow 0: None 1: The trim value is out of limits when AUTOTRIMEN = 1</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>FECOVF</name>
              <description>Frequency Error Capture Over Flow 0: None 1: The Counter value changed in the increasing direction and the counter value increased to the end (0xFFFF)</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>SYNCLVL_4</name>
              <description>FETHR * 128 &lt; HSICMU_CAP</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>SYNCLVL_3</name>
              <description>FETHR * 4 &lt; HSICMU_CAP &lt;= FETHR * 128</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>SYNCLVL_2</name>
              <description>FETHR * 2 &lt; HSICMU_CAP &lt;= FETHR *4</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>SYNCLVL_1</name>
              <description>FETHR &lt; HSICMU_CAP &lt;= FETHR * 2</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>SYNCLVL_0</name>
              <description>HSICMU_CAP &lt;= FETHR</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>ICR</name>
          <description>High Speed Internal OSC Clock Management Unit Interrupt &amp; Status Clear Register</description>
          <addressOffset>0x000C</addressOffset>
          <size>0x20</size>
          <access>write-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SYNC_FLAG</name>
              <description>Sync Signal Flag clear</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>TRIMOVF</name>
              <description>Trim Value Over flow flag clear</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>FECOVF</name>
              <description>Frequency Error Over Flow flag clear</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>SYNCLVL_4</name>
              <description>SYNCLVL_4</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>SYNCLVL_3</name>
              <description>SYNCLVL_3</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>SYNCLVL_2</name>
              <description>SYNCLVL_2</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>SYNCLVL_1</name>
              <description>SYNCLVL_1</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>SYNCLVL_0</name>
              <description>SYNCLVL_0</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>TRIM</name>
          <description>High Speed Internal OSC Clock Management Unit TRIM Register</description>
          <addressOffset>0x0010</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TRIM</name>
              <description>Trim value register for trimming</description>
              <bitOffset>0</bitOffset>
              <bitWidth>11</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>ATRIM</name>
          <description>High Speed Internal OSC Clock Management Unit Auto TRIM Register</description>
          <addressOffset>0x0014</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>ATRIM</name>
              <description>Current trim value during auto trimming</description>
              <bitOffset>0</bitOffset>
              <bitWidth>11</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
