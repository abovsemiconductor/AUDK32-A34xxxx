            <field>
              <name>UPDATE</name>
              <description>Set when FADR is written. Cleared when the new address takes effect (at the end of the current transfer).</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>FADDR</name>
              <description>The function address</description>
              <bitOffset>0</bitOffset>
              <bitWidth>7</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>POWER</name>
          <description>Power management register</description>
          <addressOffset>0x0004</addressOffset>
          <size>0x08</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>ISOUPDATE</name>
              <description>When set by the CPU, this Device will wait for an SOF token from the time InPktRdy is set before sending the packet. If an IN token is received before an SOF token, then a zero length data packet will be sent. This bit is only used by endpoints performing Isochronous transfers.</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>RESET</name>
              <description>set while reset signaling is present on the bus</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>RESUME</name>
              <description>Set by the cpu to generate resume signaling when the function is in suspend mode.</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SUSPENDMD</name>
              <description>Set by the USB when suspend mode is entered.</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>SUSPENDEN</name>
              <description>Set by the CPU to enable entry into suspend mode when suspend signaling is received on the bus</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>INTRIN1</name>
          <description>Interrupt Flag Register for Endpoint 0 plus IN Endpoints 1 to 5</description>
          <addressOffset>0x0008</addressOffset>
          <size>0x08</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>EP5IFG</name>
              <description>IN Endpoint 5 interrupt</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>EP4IFG</name>
              <description>IN Endpoint 4 interrupt</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>EP3IFG</name>
              <description>IN Endpoint 3 interrupt</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>EP2IFG</name>
              <description>IN Endpoint 2 interrupt</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>EP1IFG</name>
              <description>IN Endpoint 1 interrupt</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>EP0IFG</name>
              <description>IN Endpoint 0 interrupt</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>INTROUT1</name>
          <description>Interrupt Flag Register for OUT Endpoints 1 to 5</description>
          <addressOffset>0x0010</addressOffset>
          <size>0x08</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>EP5IFG</name>
              <description>OUT Endpoint 5 interrupt</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>EP4IFG</name>
              <description>OUT Endpoint 4 interrupt</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>EP3IFG</name>
              <description>OUT Endpoint 3 interrupt</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>EP2IFG</name>
              <description>OUT Endpoint 2 interrupt</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>EP1IFG</name>
              <description>OUT Endpoint 1 interrupt</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>INTRUSB</name>
          <description>Interrupt Enable Register for Common USB Interrupts</description>
          <addressOffset>0x0018</addressOffset>
          <size>0x08</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SOFIFG</name>
              <description>Set at the start of each frame</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>RESETIFG</name>
              <description>Set when reset signaling is detected on the bus</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>RESUMEIFG</name>
              <description>Set when resume signaling is detected on the bus while the this Device is in suspend mode</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>SUSPENDIFG</name>
              <description>Set when suspend signaling is detected on the bus.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>INTRIN1E</name>
          <description>Interrupt Enable Register for Endpoint 0 plus IN Endpoints 1 to 5</description>
          <addressOffset>0x001C</addressOffset>
          <size>0x08</size>
          <access>read-write</access>
          <resetValue>0x0000003F</resetValue>
          <fields>
            <field>
              <name>EP5IEN</name>
              <description>Interrupt enable for EP5 IN</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>EP4IEN</name>
              <description>Interrupt enable for EP4 IN</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>EP3IEN</name>
              <description>Interrupt enable for EP3 IN</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>EP2IEN</name>
              <description>Interrupt enable for EP2 IN</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>EP1IEN</name>
              <description>Interrupt enable for EP1 IN</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>EP0IEN</name>
              <description>Interrupt enable for EP0 IN</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>INTROUT1E</name>
          <description>Interrupt Enable Register for OUT Endpoints 1 to 5</description>
          <addressOffset>0x0024</addressOffset>
          <size>0x08</size>
          <access>read-write</access>
          <resetValue>0x0000003E</resetValue>
          <fields>
            <field>
              <name>EP5IEN</name>
              <description>Interrupt enable for EP5 OUT</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>EP4IEN</name>
              <description>Interrupt enable for EP4 OUT</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>EP3IEN</name>
              <description>Interrupt enable for EP3 OUT</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>EP2IEN</name>
              <description>Interrupt enable for EP2 OUT</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>EP1IEN</name>
              <description>Interrupt enable for EP1 OUT</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>INTRUSBE</name>
          <description>Interrupt Enable Register for Common USB Interrupts</description>
          <addressOffset>0x002C</addressOffset>
          <size>0x08</size>
          <access>read-write</access>
          <resetValue>0x00000006</resetValue>
          <fields>
            <field>
              <name>SOFIEN</name>
              <description>Interrupt Enable for SOF</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>RESETIEN</name>
              <description>Interrupt Enable for Reset</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>RESUMEIEN</name>
              <description>Interrupt Enable for Resume</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SUSPENDIEN</name>
              <description>Interrupt Enable for Suspend</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>FRAME1</name>
          <description>Frame number bit 0 to 7</description>
          <addressOffset>0x0030</addressOffset>
          <size>0x08</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>FRMNO</name>
              <description>Lower 8 bits of Frame Number</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>FRAME2</name>
          <description>Frame number bit 8 to 10</description>
          <addressOffset>0x0034</addressOffset>
          <size>0x08</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>FRMNO</name>
              <description>Upper 3 bits of Frame Number</description>
              <bitOffset>0</bitOffset>
              <bitWidth>3</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>INDEX</name>
          <description>Index Register for Selecting the Endpoint Status and Control Registers</description>
          <addressOffset>0x0038</addressOffset>
          <size>0x08</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>INDEX</name>
              <description>Selected Endpoint</description>
              <bitOffset>0</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>PUPDCR</name>
          <description>DP/DN Pins Pull-up/Down Resistor Control Register</description>
          <addressOffset>0x0040</addressOffset>
          <size>0x08</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>DNPDEN</name>
              <description>DN Pin Pull-down resistor enable bit</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>DNPUEN</name>
              <description>DN Pin Pull-up resistor enable bit</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>DPPDEN</name>
              <description>DP Pin Pull-down resistor enable bit</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>DPPUEN</name>
              <description>DP Pin Pull-up resistor enable bit</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>PHYCR</name>
          <description>USB Power control register</description>
          <addressOffset>0x0044</addressOffset>
          <size>0x08</size>
          <access>read-write</access>
          <resetValue>0x00000001</resetValue>
          <fields>
            <field>
              <name>PHYSUSP_MODE</name>
              <description>USB PHY IP changed suspend mode</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>INMAXP</name>
          <description>Maximum Packet Size for IN Endpoint. (Index Register set to select Endpoints 1 5 only)</description>
          <addressOffset>0x0050</addressOffset>
          <size>0x08</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>INMAXPS</name>
              <description>Maximum Packet Size / transaction for IN endpoint. 8 bytes unit. (ex. 0x04 = 32bytes, but 0x80 = 1023 bytes)</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>CSR0_INCSR1</name>
          <description>Control Status Register for Endpoint 0. (Index Register set to select Endpoint 0), Control Status Register 1 for IN Endpoint. (Index Register set to select Endpoints 1 5)</description>
          <addressOffset>0x0054</addressOffset>
          <size>0x08</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SERVICEDSETUPEND</name>
              <description>Clear the SetupEnd bit.(Index Register set to select Endpoint 0),</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SERVICEDOUTPKTRDY_CLRDATATOG</name>
              <description>Clear the OutPktRdy bit.(Index Register set to select Endpoint 0), Reset the endpoint IN data toggle to 0(Index Register set to select Endpoints 1 5)</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SENDSTALL_SENTSTALL</name>
              <description>set to terminate the current transaction(Index Register set to select Endpoint 0), Detect when a STALL handshake is transmitted. The FIFO is flushed and the InPktRdy bit is cleared. The CPU should clear this bit.(Index Register set to select Endpoints 1 5)</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SETUPEND_SENDSTALL</name>
              <description>Detected when a control transaction ends before the DataEnd bit has been set. An interrupt will be generated and the FIFO flushed at this time.(Index Register set to select Endpoint 0), Set to issue a STALL handshake to an IN token. The CPU clears this bit to terminate the stall condition. This bit has no effect if the IN endpoint is in ISO mode.(Index Register set to select Endpoints 1 5)</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>DATAEND_FLUSHFIFO</name>
              <description>The CPU sets this bit when : 1.setting InPktRdy for the last data packet 2.clearing OutPktRdy after unloading the last data packet 3.setting InPktRdy for a zero length data packet (Index Register set to select Endpoint 0), Set to flush the next packet to be transmitted from the endpoint IN FIFO. The FIFO pointer is reset and the InPktRdy bit is cleared. Note : If the FIFO contains two packets, FlushFIFO will need to be set twice to completely clear the FIFO..(Index Register set to select Endpoints 1 5)</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SENTSTALL_UNDERRUN</name>
              <description>Set when a STALL handshake is transmitted. The CPU should clear tis bit.(Index Register set to select Endpoint 0), In ISO mode, this bit is set when a zero length data packet is sent after receiving an IN token with the InPktRdy bit not set. In Bulk/Interrupt mode, this bit is set when a NAK is returned in response to an IN token. The CPU should clear this bit.(Index Register set to select Endpoints 1 5)</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>INPKTRDY_FIFONOTEMPTY</name>
              <description>set after loading a data packet into the FIFO. An interrupt is generated when the bit is cleared.(Index Register set to select Endpoint 0), This bit is set when there is a lease 1 packet in the IN FIFO.(Index Register set to select Endpoints 1 5)</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>OUTPKTRDY_INPKTRDY</name>
              <description>This bit is set when a data packet has been received. An interrupt is generated when this bit is set.(Index Register set to select Endpoint 0), Set after loading a data packet into the FIFO. It is cleared automatically when a data packet has been transmitted. An interrupt is generated (if enabled) when the bit is cleared.(Index Register set to select Endpoints 1 5)</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>INCSR2</name>
          <description>Control Status Register 2 for IN Endpoint. (Index Register set to select Endpoints 1 5 only)</description>
          <addressOffset>0x0058</addressOffset>
          <size>0x08</size>
          <access>read-write</access>
          <resetValue>0x00000020</resetValue>
          <fields>
            <field>
              <name>AUTOSET</name>
              <description>If the CPU set this bit, InPktRdy will be automatically set when data of the maximum packet size (value in InMaxP) is loaded into the IN FIFO. If a packet of less than the maximum packet size is loaded, then InPktRdy will have to be set manually.</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>ISO</name>
              <description>Enable the IN endpoint for isochronous transfers (ISO mode), and clears it to enable the IN endpoint for bulk/interrupt transfers.</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>MODE</name>
              <description>Set the endpoint direction. Valid only when the same endpoint FIFO is used for both IN and OUT transactions.</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>DMAENAB</name>
              <description>Set to enable the DMA request for the IN endpoint.</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>FRCDATATOG</name>
              <description>Set to force the endpoints IN data toggle to switch after each data packet is sent regardless of whether an ACK was received. This can be used by interrupt IN endpoints which are used to communicated rate feedback for Isochronous endpoints.</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>OUTMAXP</name>
          <description>Maximum Packet Size for OUT Endpoint. (Index Register set to select Endpoints 1 5 only)</description>
          <addressOffset>0x005C</addressOffset>
          <size>0x08</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>OUTMAXPS</name>
              <description>Maximum Packet Size / transaction</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>OUTCSR1</name>
          <description>Control Status Register 1 for OUT Endpoint. (Index Register set to select Endpoints 1 5 only)</description>
          <addressOffset>0x0060</addressOffset>
          <size>0x08</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CLRDATATOG</name>
              <description>Reset the Endpoint data toggle to 0</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SENTSTALL</name>
              <description>Detect STALL handshake</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SENDSTALL</name>
              <description>Issue a STALL handshake. Ignored in ISO mode</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FLUSHFIFO</name>
              <description>Flush the next packet to be read from the endpoint OUT FIFO. Note : if the FIFO contains two packets, FlushFIFO will need to be set twice to completely clear the FIFO</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DATAERROR</name>
              <description>Set when OutPktRdy is set if the data packet has a CRC or bit-stuff error. This bit is only valid in ISO mode.</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>OVERRUN</name>
              <description>Set if an OUT packet cannot be loaded into the OUT FIFO. The CPU should clear this bit. The bit is only valid is ISO mode</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FIFOFULL</name>
              <description>Set when no more packets can be loaded into the OUT FIFO</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>OUTPKTRDY</name>
              <description>Set when a data packet has been received. The CPU should clear this bit when the packet has been unloaded from the OUT FIFO. An interrupt is generated when the bit is set.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>OUTCSR2</name>
          <description>Control Status Register 2 for OUT Endpoint. (Index Register set to select Endpoints 1 5 only)</description>
          <addressOffset>0x0064</addressOffset>
          <size>0x08</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>AUTOCLEAR</name>
              <description>If the CPU set this bit then the OutPktRdy bit will be automatically cleared when a packet of OutMaxP bytes has been unloaded from the OUT FIFO. When packets of less than the maximum packet size are unloaded, OutPktRdy will have to be cleared manually.</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>ISO</name>
              <description>Enable the OUT endpoint for Isochronous transfers, and clears it to enable the OUT endpoint for Bulk/Interrupt transfers.</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>DMAENAB</name>
              <description>Enable the DMA request for the OUT endpoints</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>DMAMODE</name>
              <description>Two modes of DMA operation are supported like below. DMA mode 0 in which a DMA request is generated for all received packets, together with an interrupt (if enabled). DMA mode 1 in which a DMA request (but no interrupt) is generated for OUT packets of size OutMaxP bytes and an interrupt (but no DMA request) is generated for OUT packets of any other size.</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>COUNT0_OUTCOUNT1</name>
          <description>Number of Received Bytes in Endpoint 0 FIFO. (Index Register set to select Endpoint 0) Number of Bytes in OUT Endpoint FIFO (Lower Byte). (Index register set to select Endpoints 1 5 only)</description>
          <addressOffset>0x0068</addressOffset>
          <size>0x08</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>EP0OUTCNT_EPOUTCNT</name>
              <description>Endpoint 0 Out Count(Index Register set to select Endpoint 0) Endpoint OUT count lower 8 bits(Index register set to select Endpoints 1 5 only)</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>OUTCOUNT2</name>
