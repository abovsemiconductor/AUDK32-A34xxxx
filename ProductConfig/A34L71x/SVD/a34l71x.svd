    <peripheral>
      <name>WDT</name>
      <groupName>WDT</groupName>
      <description>WATCH-DOG TIMER</description>
      <baseAddress>0x40000200</baseAddress>
      <addressBlock>
        <offset>0x00000000</offset>
        <size>0x0100</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>WDT</name>
        <value>6</value>
      </interrupt>
      <registers>
        <register>
          <name>LR</name>
          <description>WDT load register</description>
          <addressOffset>0x0000</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>LR</name>
              <description>WDT load value register</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>CNT</name>
          <description>WDT current count register</description>
          <addressOffset>0x0004</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x000009C4</resetValue>
          <fields>
            <field>
              <name>CNT</name>
              <description>WDT current counter register</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>CON</name>
          <description>WDT control register</description>
          <addressOffset>0x0008</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x0000805C</resetValue>
          <fields>
            <field>
              <name>LP_UPDATE</name>
              <description>indicates whether it is currently being updated. If WDT_CLK is significantly slower than MCLK, an update error in the WDT_LR register may occur.</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>WDBG</name>
              <description>Whether to enable or disable the WDT in debug mode</description>
              <bitOffset>15</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>WUF</name>
              <description>WDT underflow flag (The bit is cleared when WDT_LR is written.)</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>WDTIE</name>
              <description>Whether to enable or disable the WDT counter underflow interrupt</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>WDTRE</name>
              <description>Whether to enable or disable the WDT counter underflow reset</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>WDTEN</name>
              <description>Whether to enable or disable the WDT counter</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>CKSEL</name>
              <description>WDTCLKIN clock source selection</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>WPRS</name>
              <description>Counter clock prescaler</description>
              <bitOffset>0</bitOffset>
              <bitWidth>3</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>WDTCLKIN_DIV_BY_1</name>
                  <description>WDT Input Clock divide by 1</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>WDTCLKIN_DIV_BY_4</name>
