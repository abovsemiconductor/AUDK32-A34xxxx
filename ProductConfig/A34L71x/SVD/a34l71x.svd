    <peripheral>
      <name>LCD</name>
      <groupName>LCD</groupName>
      <description>LCD Driver</description>
      <baseAddress>0x40005000</baseAddress>
      <addressBlock>
        <offset>0x00000000</offset>
        <size>0x0100</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <name>CR</name>
          <description>LCD Driver Control Register</description>
          <addressOffset>0x0000</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>VLCDS</name>
              <description>Selection VLCD Power(only when a resistor bias type is selected)</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>IntPower</name>
                  <description>Internal Power for VLCD</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ExtPower</name>
                  <description>External Power for VLCD</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>BTYPE</name>
              <description>LCD Bias Type Selection</description>
              <bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>IntRBias</name>
                  <description>Internal Resistor Bias</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ExtRBias</name>
                  <description>External Resistor Bias</description>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CapBias</name>
                  <description>Capacitor Bias (Voltage Booster)</description>
                  <value>2</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>IRSEL</name>
              <description>Internal LCD Bias Dividing Resistor Selection</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>RLCD2</name>
                  <description>100[kohm]</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>RLCD1</name>
                  <description>10[kohm]</description>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>RLCD3</name>
                  <description>50[kohm]</description>
                  <value>2</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>DBS</name>
              <description>LCD Duty and Bias Selection</description>
              <bitOffset>3</bitOffset>
              <bitWidth>3</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>8D4B</name>
                  <description>1/8 duty, 1/4 bias</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>6D4B</name>
                  <description>1/6 duty, 1/4 bias</description>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>5D3B</name>
                  <description>1/5 duty, 1/3 bias</description>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>4D3B</name>
                  <description>1/4 duty, 1/3 bias</description>
                  <value>3</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>3D3B</name>
                  <description>1/3 duty, 1/3 bias</description>
                  <value>4</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>3D2B</name>
                  <description>1/3 duty, 1/2 bias</description>
                  <value>5</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>2D2B</name>
                  <description>1/2 duty, 1/2 bias</description>
                  <value>6</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>LCLK</name>
              <description>LCD Clock Selection (When fLCD = 32.768kHz)</description>
              <bitOffset>1</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>128Hz</name>
                  <description>32.768kHz(fLCD) / 256</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>256Hz</name>
                  <description>32.768kHz(fLCD) / 128</description>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>512Hz</name>
                  <description>32.768kHz(fLCD) / 64</description>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>1024Hz</name>
                  <description>32.768kHz(fLCD) / 32</description>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>DISP</name>
              <description>LCD Display Control</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>Off</name>
                  <description>Display off</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>On</name>
                  <description>Normal display on</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
          </fields>
