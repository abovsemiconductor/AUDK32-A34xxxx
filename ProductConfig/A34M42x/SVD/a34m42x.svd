              <enumeratedValues>
                <enumeratedValue>
                  <name>Disable</name>
                  <description>Disable data cache</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>Enable</name>
                  <description>Enable data cache</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>ICEN</name>
              <description>Whether to Enable or Disable Instruction Cache</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>Disable</name>
                  <description>Disable instruction cache</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
