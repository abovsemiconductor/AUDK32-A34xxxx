    <peripheral>
      <name>DFMC</name>
      <groupName>DFMC</groupName>
      <description>DATA FLASH MEMORY CONTROLLER</description>
      <baseAddress>0x41001000</baseAddress>
      <addressBlock>
        <offset>0x00000000</offset>
        <size>0x1000</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>DFMC</name>
        <value>12</value>
      </interrupt>
