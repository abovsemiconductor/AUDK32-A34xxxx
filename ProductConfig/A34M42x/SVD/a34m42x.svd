        <register>
          <name>CONF</name>
          <description>Data Flash Memory Config Register</description>
          <addressOffset>0x0000</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
<!--	Hidden Register Data Flash ECC bit
            <field>
              <name>ECCDIS</name>
              <description>Whether to Enable or Disable Data FLASH ECC</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>Disable</name>
                  <description>ECC enable</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>Enable</name>
                  <description>ECC disable</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
-->			
            <field>
              <name>WRITE</name>
              <description>Whether to Enable or Disable the Data Flash Write</description>
              <bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>Disable</name>
                  <description>Disable write</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>Enable</name>
                  <description>Enable write</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
