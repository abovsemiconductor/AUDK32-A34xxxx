filestr='04_adc_intr_multiple_8_sequence_data'
chkstr=''
delay=1
NeedReview=1
call dotest
pause 1

filestr='05_adc_intr_multiple_8_sequence_data_with_timer1'
chkstr=''
delay=1
NeedReview=1
call dotest
mpause 30
sendln 'cm timer1'
mpause 30
sendln 'stop 0'
mpause 30
sendln 'stop 1'
mpause 30
sendln 'stop 2'
pause 1

filestr='06_adc_intr_burst_8_sequence_data_with_mpwm0'
chkstr=''
delay=10
NeedReview=1
call dotest
sendln 'stop 0'
mpause 30
sendln 'cm mpwm'
mpause 30
sendln 'stop 0 c'
pause 1

filestr='07_adc_intr_multiple_8_sequence_data_with_mpwm0'
chkstr=''
delay=10
NeedReview=1
call dotest
sendln 'stop 0'
mpause 30
sendln 'cm mpwm'
mpause 30
sendln 'stop 0 c'
pause 1

filestr='08_adc_intr_single_1_sequence_data_compare_up_with_timer11_event_timer10_input'
chkstr=''
delay=90
NeedReview=1
call dotest
mpause 30
sendln 'stop 0'
mpause 30
sendln 'cmp 0 d'
mpause 30
sendln 'cm timer1'
mpause 30
sendln 'stop 0'
mpause 30
sendln 'stop 1'
pause 1

filestr='09_adc_intr_single_1_sequence_data_compare_down_with_timer11_event_timer10_input'
chkstr=''
delay=90
NeedReview=1
call dotest
mpause 30
sendln 'stop 0'
mpause 30
sendln 'cmp 0 d'
mpause 30
sendln 'cm timer1'
mpause 30
sendln 'stop 0'
mpause 30
sendln 'stop 1'
pause 1

filestr='10_adc_dma_multiple_8_sequence_data_with_mpwm0'
chkstr=''
delay=10
NeedReview=1
call dotest
sendln 'stop 0'
mpause 30
sendln 'cm mpwm'
mpause 30
sendln 'stop 0 c'
pause 1

filestr='11_adc_intr_non_maskable_multiple_8_sequence_data_with_timer1'
chkstr=''
delay=1
NeedReview=1
call dotest
sendln 'stop 0'
mpause 30
sendln 'cm timer1'
mpause 30
sendln 'stop 0'
mpause 30
sendln 'stop 1'
mpause 30
sendln 'stop 2'
pause 1

filestr='12_adc_dma_non_maskable_multiple_8_sequence_data_with_timer1'
chkstr=''
delay=1
NeedReview=1
call dotest
sendln 'stop 0'
mpause 30
sendln 'cm timer1'
mpause 30
sendln 'stop 0'
mpause 30
sendln 'stop 1'
mpause 30
sendln 'stop 2'
pause 1
NeedReview=0

; ===== END : TestCase ADC =====
dispstr 10
dispstr '===== END : TestCase ADC ====='
dispstr 10
return

