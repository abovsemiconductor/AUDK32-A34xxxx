; A. Description
;    This script automatically executes WDT, FRT, CRC, AES, RNG, FMC, some of Timer1, ADC, some of PCU, and SCU Tera Term example scripts.
;
; B. Prerequisite Example (abov_example_config.h)
;    1. PCU/GPIO
;    2. WDT
;    3. FRT
;    4. FMC
;    5. SCU
;    6. Timer1
;    7. ADC
;    8. AES
;    9. CRC
;    10. RNG
;    11. MPWM
;
; C. Port Connection
;    1. ADC
;       : PC4 (Timer10 Output) ----> PA5 (AN5)
;       : PB0 (MPWM0) ----> PA6 (AN6)
;       : PB1 (MPWM0) ----> PA7 (AN7)
;       : PB2 (MPWM0) ----> PA8 (AN8)
;       : PB4 (MPWM0) ----> PA10 (AN10)
;    2. PCU
;       : PA0 (Output) ----> PE0 (Input)

timeout=3000
Passstr='===== Test Result : Pass ====='#13#10
Failstr='===== Test Result : Fail ====='#13#10
Reviewstr='===== Test Result : Need Review ===='#13#10
NeedReview=0

getdir mdir
foldercreate 'Result'

fileret='01_Autotest_Result_WDT_FRT_CRC_AES_FMC_PCU_SCU_ADC_TIMER1'
sprintf2 retfilename '%s\Result\%s.txt' mdir fileret
sprintf2 delfilename 'Result\%s.txt' fileret
filedelete delfilename
fileopen frethnd retfilename 0

call tcwdt
call tcfrt
call tccrc
call tcaes
call tcrng
call tcpcu
call tcscu
call tctimer1
call tcadc
call tcfmc

fileclose frethnd
dispstr 'End of 1. Auto Test WDT/FRT/CRC/FMC/PCU/SCU/ADC/AFE/Timer1'
dispstr 10
dispstr 'Must process the remained PCU/SCU TC.'
end

:tcwdt
; ===== START : TestCase WDT =====
dispstr 10 10
dispstr '===== START : TestCase WDT ====='
dispstr 10

ipstr='WDT'
foldercreate ipstr

filestr='01_wdt_intr_maskable_underflow'
chkstr='WDT : (0) U evt fired'
delay=5
call dotest
sendln 'stop 0'
pause 1

filestr='02_wdt_intr_non_maskable_underflow'
chkstr='WDT : (0) U evt fired'
delay=5
call dotest
sendln 'stop 0'
pause 1

filestr='03_wdt_intr_reset'
chkstr='= Executable module list ='
delay=10
call dotest

; ===== END : TestCase WDT =====
dispstr 10
dispstr '===== END : TestCase WDT ====='
dispstr 10
return

