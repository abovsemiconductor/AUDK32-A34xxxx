; A. Description
;    A list of commands here configures USART as SPI and receives data.
;
; B. Preparation
;    Connecting ports with a suitable instrument should be correct
;
; C. Prerequisite Example (abov_example_config.h)
;    1. USART
;    2. PCU/GPIO
;
; D. Default Port
;    1. USART0  : PB13 (Slave Select)
;               : PB14 (Serial Clock)
;               : PB15 (Master Out Slave In)
;               : PC0 (Master In Slave Out)
;    2. USART1  : PC8 (Slave Select)
;               : PC9 (Serial Clock)
;               : PC10 (Master Out Slave In)
;               : PC11 (Master In Slave Out)
;
; E. Port Connection
;    1. PB13 (Slave Select)        <----> PC8  (Slave Select)
;    2. PB14 (Serial Clock)        <----> PC9  (Serial Clock)
;    3. PB15 (Master Out Slave In) <----> PC11 (Master In Slave Out)
;    4. PC0 (Master In Slave Out)  <----> PC10 (Master Out Slave In)
;
; For more information, read a user's manual of the target device carefully.
;
; USART0
; 1. Channel                   : 0 (USART0)
;
; 2. Config                    : [ 0 d s m m l e -swap 7 ]
;    Operation                 : d (DMA)
;    USART Mode                : s (SPI)
;    SPI Mode                  : m (Master)
;    Bit Order                 : m (MSB)
;    Polarity                  : l (Low)
;    Phase                     : e (Even Edge)
;    Swap MOSI/MISO port       : Swap
;    Baudrate                  : 7
;
; 3. Data                      : [ 0 8 0xff 0xa5 0x5a 0xff 0x01 0x10 0x55 0xaa ]
;    Data Length               : 8
;    Data                      : 0xa5 ... (Hexa and space (delimitor))
;
; 4. Tx                        : [ 0 8 ]
;    Receive Data Length       : 8
;
; USART1
; 1. Channel                   : 1 (USART1)
;
; 2. Config                    : [ 1 d s s m l e 7 ]
;    Operation                 : d (DMA)
;    USART Mode                : s (SPI)
;    SPI Mode                  : s (Slave)
;    Bit Order                 : m (MSB)
;    Polarity                  : l (Low)
;    Phase                     : e (Even Edge)
;    Baudrate                  : 7
;
; 3. Rx                        : [ 1 8 ]
;    Receive Data Length       : 8
;
; PCU (PB/Cx)
; 1. Port Group                : 1 / 2 (PCU Port B/C)
;
; 2. Port                      : [ 1 13 a 4 ] [ 1 14 a 4 ] [ 1 15 a 4 ] [ 2 0 a 4 ]
;    Pin Number                : 13 / 14 / 15 / 0
;    Pin Mode                  : a (Alternative)
;    Alternative               : 4 (SS/SCK/MOSI/MISO)
;
; PCU (PCx)
; 1. Port Group                : 2 (PCU Port C)
;
; 2. Port                      : [ 2 8 a 4 ] [ 2 9 a 4 ] [ 2 10 a 4 ] [ 2 11 a 4 ]
;    Pin Number                : 8 / 9 / 10 / 11
;    Pin Mode                  : a (Alternative)
;    Alternative               : 4 (SS/SCK/MOSI/MISO)
;
; PCU (PB/Cx)
sendln 'cm pcu'
mpause 30
sendln 'port 1 13 a 4'
mpause 30
sendln 'port 1 14 a 4'
mpause 30
sendln 'port 1 15 a 4'
mpause 30
sendln 'port 2 0 a 4'
mpause 30

; PCU (PCx)
sendln 'port 2 8 a 4'
mpause 30
sendln 'port 2 9 a 4'
mpause 30
sendln 'port 2 10 a 4'
mpause 30
sendln 'port 2 11 a 4'
mpause 30

; USART1
sendln 'cm usart'
mpause 30
sendln 'uninit 1'
mpause 30
sendln 'init 1'
mpause 30
sendln 'config 1 d s s m l e -swap 7'
mpause 30
sendln 'rx 1 8'
mpause 30

; USART0
sendln 'cm usart'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'config 0 d s m m l e 7'
mpause 30
sendln 'data 0 8 0xff 0xa5 0x5a 0xff 0x01 0x10 0x55 0xaa'
mpause 100
sendln 'tx 0 8'
