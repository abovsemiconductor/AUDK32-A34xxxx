; A. Description
;    A list of commands here configures USART as USRT and receives data.
;
; B. Preparation
;    Connecting ports with a suitable instrument should be correct
;
; C. Prerequisite Example (abov_example_config.h)
;    1. USART
;    2. PCU/GPIO
;
; D. Default Port
;    1. USART0  : PB14 (Serial Clock)
;               : PB15 (Transmit)
;               : PC0 (Receive)
;    2. USART1  : PC9 (Serial Clock)
;               : PC10 (Transmit)
;               : PC11 (Receive)
;
; E. Port Connection
;    1. PB14 (Serial Clock) <----> PC9  (Serial Clock)
;    2. PB15 (Transmit)     <----> PC11 (Receive)
;    3. PC0  (Receive)      <----> PC10 (Transmit)
;
; For more information, read a user's manual of the target device carefully.
;
; USART0
; 1. Channel                   : 0 (USART0)
;
; 2. Config                    : [ 0 i a m 5 n 1 0 38400 ]
;    Operation                 : i (Interrupt)
;    USART Mode                : a (USRT)
;    USRT Mode                 : m (Master)
;    Data Bit                  : 5 (5bit)
;    Parity                    : n (None)
;    Stop Bit                  : 1 (1bit)
;    Polarity                  : 0 (Tx Rising and Rx Falling Edge)
;    Baudrate                  : 38400 bps
;
; 3. Data                      : [ 0 8 0xaa 0x55 0x10 0x01 0xff 0x5a 0xa5 0xff ]
;    Data Length               : 8
;    Data                      : 0xa5 ... (Hexa and space (delimitor))
;
; 4. Tx                        : [ 0 8 ]
;    Receive Data Length       : 8
;
; USART1
; 1. Channel                   : 1 (USART1)
;
; 2. Config                    : [ 1 i a s 5 n 1 0 38400 ]
;    Operation                 : i (Interrupt)
;    USART Mode                : a (USRT)
;    USRT Mode                 : s (Slave)
;    Data Bit                  : 5 (5bit)
;    Parity                    : n (None)
;    Stop Bit                  : 1 (1bit)
;    Polarity                  : 0 (Tx Rising and Rx Falling Edge)
;    Baudrate                  : 38400 bps
;
; 3. Rx                        : [ 1 8 ]
;    Receive Data Length       : 8
;
; PCU (PB/Cx)
; 1. Port Group                : 1 / 2 (PCU Port B / C)
;
; 2. Port                      : [ 1 14 a 4 -pupd p ] [ 1 15 a 1 -pupd p ] [ 2 0 a 1 -pupd p ]
;    Pin Number                : 14 / 15 / 0
;    Pin Mode                  : a (Alternative)
;    Alternative               : 4 / 1 (SCK/Tx/Rx)
;    Pull-up/down              : p (Pull-up)
;
; PCU (PCx)
; 1. Port Group                : 2 (PCU Port C)
;
; 2. Port                      : [ 2 9 a 1 -pupd p ] [ 2 10 a 1 -pupd p ] [ 2 11 a 1 -pupd p ]
;    Pin Number                : 9 / 10 / 11
;    Pin Mode                  : a (Alternative)
;    Alternative               : 4 / 1 (SCK/Tx/Rx)
;    Pull-up/down              : p (Pull-up)

; PCU (PB/Cx)
sendln 'cm pcu'
mpause 30
sendln 'port 1 14 a 4 -pupd p'
mpause 30
sendln 'port 1 15 a 1 -pupd p'
mpause 30
sendln 'port 2 0 a 1 -pupd p'
mpause 30

; PCU (PCx)
sendln 'port 2 9 a 4 -pupd p'
mpause 30
sendln 'port 2 10 a 1 -pupd p'
mpause 30
sendln 'port 2 11 a 1 -pupd p'
mpause 30

; USART1
sendln 'cm usart'
mpause 30
sendln 'uninit 1'
mpause 30
sendln 'init 1'
mpause 30
sendln 'config 1 i a s 5 n 1 0 38400'
mpause 30
sendln 'rx 1 8'
mpause 30

; USART0
sendln 'cm usart'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'config 0 i a m 5 n 1 0 38400'
mpause 30
sendln 'data 0 8 0xaa 0x55 0x10 0x01 0xff 0x5a 0xa5 0xff'
mpause 30
sendln 'tx 0 8'
