; A. Description
;    A list of commands here configures LPUART and transmits/receives data.
;
; B. Preparation
;    Connecting ports with a suitable instrument should be correct
;
; C. Prerequisite Example (abov_example_config.h)
;    1. LPUART
;    2. PCU/GPIO
;
; D. Default Port
;    1. LPUART0 : PB15 (Transmit)
;               : PC0 (Receive)
;    2. LPUART1 : PC10 (Transmit)
;               : PC11 (Receive)
;
; E. Port Connection
;    1. PB15 (Transmit) <----> PC11 (Receive)
;    2. PC0 (Receive)   <----> PC10 (Transmit)
;
; For more information, read a user's manual of the target device carefully.
;
; LPUART0
; 1. Channel                   : 0 (LPUART0)
;
; 2. CLK                       : [ 0 m h 0 ]
;    Source                    : m (MCCR : Misc Clock)
;    MCCR Source               : h (HSI : High Speed Internal Clock - 32MHz)
;    Source Divide             : 0 (Not available)
;
; 3. Config                    : [ 0 i 8 o 1 38400 ]
;    Operation                 : i (Interrupt)
;    Data Bit                  : 8 (8bit)
;    Parity                    : o (odd)
;    Stop Bit                  : 1 (1bit)
;    Baudrate                  : 38400 bps
;
; 4. Rx                        : [ 0 8 ]
;    Receive Data Length       : 8
;
; LPUART1
; 1. Channel                   : 1 (LPUART1)
;
; 2. CLK                       : [ 1 m h 0 ]
;    Source                    : m (MCCR : Misc Clock)
;    MCCR Source               : h (HSI : High Speed Internal Clock - 32MHz)
;    Source Divide             : 0 (Not available)
;
; 3. Config                    : [ 1 i 8 o 1 38400 ]
;    Operation                 : i (Interrupt)
;    Data Bit                  : 8 (8bit)
;    Parity                    : o (odd)
;    Stop Bit                  : 1 (1bit)
;    Baudrate                  : 38400 bps
;
; 4. Data                      : [ 1 8 0xa5 0x5a 0xa5 0x5a 0x05 0x07 0x09 0xa0 ]
;    Data Length               : 8
;    Data                      : 0xa5 ... (Hexa and space (delimitor))
;
; 5. Tx                        : [ 1 8 ]
;    Receive Data Length       : 8
;
; PCU (PB/Cx)
; 1. Port Group                : 1 / 2 (PCU Port B/C)
;
; 2. Port                      : [ 1 15 a 3 -pupd p ] [ 2 0 a 3 -pupd p ]
;    Pin Number                : 15 / 0 
;    Pin Mode                  : a (Alternative)
;    Alternative               : 3 (TX/RX)
;    Pull-up/down              : p (Pull-up)
;
; PCU (PCx)
; 1. Port Group                : 2 (PCU Port C)
;
; 2. Port                      : [ 2 10 a 3 -pupd p ] [ 2 11 a 3 -pupd p ]
;    Pin Number                : 10 / 11 
;    Pin Mode                  : a (Alternative)
;    Alternative               : 3 (TX/RX)
;    Pull-up/down              : p (Pull-up)
;
; PCU (PB/Cx)
sendln 'cm pcu'
mpause 30
sendln 'port 1 15 a 3 -pupd p'
mpause 30
sendln 'port 2 0 a 3 -pupd p'
mpause 30

; PCU (PCx)
sendln 'port 2 10 a 3 -pupd p'
mpause 30
sendln 'port 2 11 a 3 -pupd p'
mpause 30

; LPUART0
sendln 'cm lpuart'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 m h 1'
mpause 30
sendln 'config 0 i 8 o 1 38400'
mpause 30
sendln 'rx 0 8'
mpause 30

; LPUART1
sendln 'uninit 1'
mpause 30
sendln 'init 1'
mpause 30
sendln 'clk 1 m h 1'
mpause 30
sendln 'config 1 i 8 o 1 38400'
mpause 30
sendln 'data 1 8 0xa5 0x5a 0xa5 0x5a 0x05 0x07 0x09 0xa0'
mpause 30
sendln 'tx 1 8'
