:tctimer1
; ===== START : TestCase Timer1 =====
dispstr 10 10
dispstr '===== START : TestCase Timer1 ====='
dispstr 10

ipstr='Timer1'
foldercreate ipstr

filestr='01_timer1_intr_period'
chkstr='TIMER1 : (0) P evt fire'
delay=2
call dotest
sendln 'stop 0'
pause 1

filestr='02_timer1_intr_oneshot'
chkstr='TIMER1 : (0) P evt fire'
delay=2
call dotest
sendln 'stop 0'
pause 1

filestr='03_timer1_intr_pwm'
chkstr='TIMER1 : (0) PWM P evt fire'
delay=3
call dotest
sendln 'stop 0'
pause 1

filestr='04_timer1_intr_capture'
chkstr=''
delay=4
NeedReview=1
call dotest
sendln 'stop 4'
mpause 30
sendln 'stop 3'
pause 1

filestr='06_timer1_intr_ext_clk_input_with_timer1'
chkstr='TIMER1 : (4) P evt fire'
delay=4
call dotest
sendln 'stop 4'
mpause 30
sendln 'stop 3'
pause 1

filestr='07_timer1_intr_non_maskable_period'
chkstr='TIMER1 : (0) P evt fire'
delay=3
call dotest
sendln 'stop 0'
pause 1

; ===== END : TestCase Timer1 =====
dispstr 10
dispstr '===== END : TestCase Timer1 ====='
dispstr 10
return

:tcadc
; ===== START : TestCase ADC =====
dispstr 10 10
dispstr '===== START : TestCase ADC ====='
dispstr 10

ipstr='ADC'
foldercreate ipstr

filestr='01_adc_intr_single_1_sequence_data_with_timer1_input'
chkstr=''
delay=1
NeedReview=1
call dotest
sendln 'stop 0'
pause 1

filestr='02_adc_intr_sequence_8_sequence_data'
chkstr=''
delay=10
NeedReview=1
call dotest
sendln 'stop 0'
pause 1

filestr='03_adc_intr_burst_8_sequence_data'
chkstr=''
delay=10
NeedReview=1
call dotest
sendln 'stop 0'
pause 1

filestr='04_adc_intr_multiple_8_sequence_data'
chkstr=''
delay=1
NeedReview=1
call dotest
pause 1

filestr='05_adc_intr_multiple_8_sequence_data_with_timer1'
chkstr=''
delay=1
NeedReview=1
call dotest
mpause 30
sendln 'cm timer1'
mpause 30
sendln 'stop 5'
mpause 30
sendln 'stop 1'
mpause 30
sendln 'stop 2'
pause 1

filestr='08_adc_intr_single_1_sequence_data_compare_up_with_timer11_event_timer10_input'
chkstr=''
delay=90
NeedReview=1
call dotest
mpause 30
sendln 'stop 0'
mpause 30
sendln 'cmp 0 d'
mpause 30
sendln 'cm timer1'
mpause 30
sendln 'stop 5'
mpause 30
sendln 'stop 2'
pause 1

filestr='09_adc_intr_single_1_sequence_data_compare_down_with_timer11_event_timer10_input'
chkstr=''
delay=90
NeedReview=1
call dotest
mpause 30
sendln 'stop 0'
mpause 30
sendln 'cmp 0 d'
mpause 30
sendln 'cm timer1'
mpause 30
sendln 'stop 5'
mpause 30
sendln 'stop 2'
pause 1

filestr='11_adc_intr_non_maskable_multiple_8_sequence_data_with_timer1'
chkstr=''
delay=1
NeedReview=1
call dotest
sendln 'stop 0'
mpause 30
sendln 'cm timer1'
mpause 30
sendln 'stop 5'
mpause 30
sendln 'stop 1'
mpause 30
sendln 'stop 2'
pause 1

filestr='12_adc_dma_non_maskable_multiple_8_sequence_data_with_timer1'
chkstr=''
delay=1
NeedReview=1
call dotest
sendln 'stop 0'
mpause 30
sendln 'cm timer1'
mpause 30
sendln 'stop 5'
mpause 30
sendln 'stop 1'
mpause 30
sendln 'stop 2'
pause 1
NeedReview=0

; ===== END : TestCase ADC =====
dispstr 10
dispstr '===== END : TestCase ADC ====='
dispstr 10
return

