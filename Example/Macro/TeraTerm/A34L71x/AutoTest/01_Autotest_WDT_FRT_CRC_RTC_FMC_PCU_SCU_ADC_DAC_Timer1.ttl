:tcrtc
; ===== START : TestCase RTC =====
dispstr 10 10
dispstr '===== START : TestCase RTC ====='
dispstr 10

ipstr='RTC'
foldercreate ipstr

filestr='01_rtc_clock_period_1sec_12h'
chkstr=''
delay=10
NeedReview=1
call dotest
NeedReview=0
sendln 'stop 0'
pause 1

filestr='02_rtc_clock_period_1sec_24h'
chkstr=''
delay=10
NeedReview=1
call dotest
NeedReview=0
sendln 'stop 0'
pause 1

filestr='03_rtc_alarm'
chkstr=''
delay=10
NeedReview=1
call dotest
NeedReview=0
sendln 'stop 0'
pause 1

filestr='04_rtc_timestamp'
chkstr=''
delay=2
NeedReview=1
call dotest
NeedReview=0
sendln 'cm rtc'
mpause 100
sendln 'stop 0'
pause 1

; ===== END : TestCase RTC =====
dispstr 10
dispstr '===== END : TestCase RTC ====='
dispstr 10
return

:dotest
sprintf2 delfilename '%s\%s.log' ipstr filestr
filedelete delfilename
sprintf2 logfilename '%s\%s\%s.log' mdir ipstr filestr
logopen logfilename 0 0
sprintf2 logstr 'Test %s%s%s' filestr #13 #10
logwrite logstr
sprintf2 tcfile '..\%s\%s.ttl' ipstr filestr 
include tcfile
pause delay
logclose
call decision
return

:decision
timeout=3000
fileopen fhandle logfilename 0
if NeedReview == 1 then
    resultstr=Reviewstr
else
    filestrseek fhandle chkstr
    if result=0 then
        resultstr=Failstr
    else 
        resultstr=Passstr
    endif
endif

fileseek fhandle 0 0
do
    filereadln fhandle line
    filewriteln frethnd line
loop while result == 0
filewriteln frethnd resultstr
filewriteln frethnd 0
filewriteln frethnd 0
fileclose fhandle
NeedReview=0
resultstr=''
pause 1

return
