; ===== START : TestCase FMC =====
dispstr 10 10
dispstr '===== START : TestCase FMC ====='
dispstr 10

ipstr='FMC'
foldercreate ipstr

filestr='01_flash'
chkstr='End of Flash'
delay=1
NeedReview=1
call dotest
NeedReview=0

; ===== END : TestCase FMC =====
dispstr 10
dispstr '===== END : TestCase FMC ====='
dispstr 10
return

:tcpcu
; ===== START : TestCase PCU =====
dispstr 10 10
dispstr '===== START : TestCase PCU ====='
dispstr 10

ipstr='PCU'
foldercreate ipstr

filestr='02_pcu_input_port_read'
delay=0
NeedReview=1
call dotest
NeedReview=0

ipstr='PCU'
filestr='04_pcu_output_port_level_change_and_input_port_read'
delay=0
NeedReview=1
call dotest
NeedReview=0

ipstr='PCU'
filestr='05_pcu_input_port_intr_with_output_port'
delay=0
NeedReview=1
call dotest
NeedReview=0

ipstr='PCU'
filestr='06_pcu_input_port_intr_non_maskable_with_output_port'
delay=0
NeedReview=1
call dotest
NeedReview=0

; ===== END : TestCase PCU =====
dispstr 10
dispstr '===== END : TestCase PCU ====='
dispstr 10
return

:tcscu
; ===== START : TestCase SCU =====
dispstr 10 10
dispstr '===== START : TestCase SCU ====='
dispstr 10

ipstr='SCU'
foldercreate ipstr

filestr='08_scu_reset'
chkstr='= Executable module list ='
delay=3
call dotest

; ===== END : TestCase SCU =====
dispstr 10
dispstr '===== END : TestCase SCU ====='
dispstr 10
