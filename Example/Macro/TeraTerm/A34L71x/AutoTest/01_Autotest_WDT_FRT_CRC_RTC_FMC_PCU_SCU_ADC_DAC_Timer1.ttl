dispstr 10 10
dispstr '===== START : TestCase CRC ====='
dispstr 10

ipstr='CRC'
foldercreate ipstr

filestr='01_crc_poll_poly_8'
chkstr='0x8f'
delay=1
call dotest

filestr='02_crc_poll_poly_16'
chkstr='0x826e'
delay=1
call dotest

filestr='03_crc_poll_poly_16_ccitt'
chkstr='0x7969'
delay=2
call dotest

filestr='04_crc_poll_poly_32'
chkstr='0xccdcd51e'
delay=1
call dotest

filestr='05_crc_dma_poly_32'
chkstr='0xccdcd51e (ISR)'
delay=1
call dotest

filestr='06_crc_dma_non_maskable_poly_32'
chkstr='0xccdcd51e (ISR)'
delay=1
call dotest

; ===== END : TestCase CRC =====
dispstr 10
dispstr '===== END : TestCase CRC ====='
dispstr 10
