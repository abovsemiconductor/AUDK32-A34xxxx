; A. Description
;    This script automatically executes WDT, FRT, CRC, RTC, FMC, some of Timer1, ADC, some of PCU, and SCU Tera Term example scripts.
;
; B. Prerequisite Example (abov_example_config.h)
;    1. PCU/GPIO
;    2. WDT
;    3. FRT
;    4. FMC
;    5. SCU
;    6. Timer1
;    7. ADC
;    8. DAC
;    9. CRC
;    10. RTC
;    11. VREFBUF
;
; C. Port Connection
;    1. ADC
;       : PE1 (Timer15 Output) ----> PD7 (AN18)
;    2. DAC
;       : PA7 (DAC0 DAO) ---> PA0 (AN0)
;    3. PCU
;       : PA9 (Output) ----> PA10 (Input)
;    4. Timer1
;       : PE14 (Timer13 Output) ----> PE15 (Timer14 Capture Input)
;    5. RTC
;       : PE11 (Output) ----> PC7 (RTC_TA)

timeout=3000
Passstr='===== Test Result : Pass ====='#13#10
Failstr='===== Test Result : Fail ====='#13#10
Reviewstr='===== Test Result : Need Review ===='#13#10
NeedReview=0

getdir mdir
foldercreate 'Result'

fileret='01_Autotest_Result_WDT_FRT_CRC_RTC_FMC_PCU_SCU_ADC_DAC_Timer1'
sprintf2 retfilename '%s\Result\%s.txt' mdir fileret
sprintf2 delfilename 'Result\%s.txt' fileret
filedelete delfilename
fileopen frethnd retfilename 0

call tcwdt
call tcfrt
call tccrc
call tcrtc
call tcpcu
call tcscu
call tctimer1
call tcadc
call tcdac
call tcfmc

fileclose frethnd
dispstr 'End of 1. Auto Test WDT/FRT/CRC/FMC/PCU/SCU/ADC/Timer1'
dispstr 10
dispstr 'Must process the remained PCU/SCU TC.'
end

:tcwdt
; ===== START : TestCase WDT =====
dispstr 10 10
dispstr '===== START : TestCase WDT ====='
dispstr 10

ipstr='WDT'
foldercreate ipstr

filestr='01_wdt_intr_maskable_underflow'
chkstr='WDT : (0) U evt fired'
delay=5
call dotest
sendln 'stop 0'
pause 1

filestr='02_wdt_intr_non_maskable_underflow'
chkstr='WDT : (0) U evt fired'
delay=5
call dotest
sendln 'stop 0'
pause 1

filestr='03_wdt_intr_reset'
chkstr='= Executable module list ='
delay=10
call dotest

; ===== END : TestCase WDT =====
dispstr 10
dispstr '===== END : TestCase WDT ====='
dispstr 10
return

:tcfrt
; ===== START : TestCase FRT =====
dispstr 10 10
dispstr '===== START : TestCase FRT ====='
dispstr 10

ipstr='FRT'
foldercreate ipstr

filestr='01_frt_intr_match'
chkstr='FRT : (0) M evt fired'
delay=5
call dotest
sendln 'stop 0'
pause 1

filestr='02_frt_intr_overflow'
chkstr='FRT : (0) O(free) evt fired' 
delay=300
call dotest
sendln 'stop 0'
pause 1

filestr='03_frt_intr_non_maskable_match'
chkstr='FRT : (0) M evt fired'
delay=5
call dotest
sendln 'stop 0'
pause 1

; ===== END : TestCase FRT =====
dispstr 10
dispstr '===== END : TestCase FRT ====='
dispstr 10
return

