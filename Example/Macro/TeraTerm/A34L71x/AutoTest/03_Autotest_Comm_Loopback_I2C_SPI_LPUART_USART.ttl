; A. Description
;    This script automatically executes I2C, UART and SPI Loopback Tera Term example scripts.
;
; B. Prerequisite Example (abov_example_config.h)
;    1. PCU/GPIO
;    2. I2C
;    3. SPI
;    4. LPUART
;    5. USART
;
; C. Port Connection
;    1. I2C0/1
;     : PB2 (Serial Clock) <----> PA12 (Serial Clock)
;     : PB3 (Serial Data)  <----> PA13 (Serial Data)
;    2. SPI0/1
;     : PA14 (Slave Select)       <----> PE4 (Slave Select)
;     : PA15 (Serial Clock)       <----> PE5 (Serial Clock)
;     : PB0 (Master Out Slave In) <----> PE6 (Master Out Slave In)
;     : PB1 (Master In Slave Out) <----> PE7 (Master In Slave Out)
;    3. USART0/1
;     : PB15 (Transmit)            <----> PC11 (Receive)
;     : PC0 (Receive)              <----> PC10 (Transmit)
;     : PB13 (Slave Select)        <----> PC8  (Slave Select)
;     : PB14 (Serial Clock)        <----> PC9  (Serial Clock)
;     : PB15 (Master Out Slave In) <----> PC11 (Master In Slave Out)
;     : PC0 (Master In Slave Out)  <----> PC10 (Master Out Slave In)
;    4. LPUART0/1
;     : PB15 (Transmit)            <----> PC11 (Receive)
;     : PC0 (Receive)              <----> PC10 (Transmit)
;

timeout=600
Passstr='===== Test Result : Pass ====='#13#10
Failstr='===== Test Result : Fail ====='#13#10
Reviewstr='===== Test Result : Need Review ===='#13#10
NeedReview=0
Datastr='0xa5 0x5a 0xa5 0x5a 0x5 0x7 0x9 0xa0 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0'
MaxDatacnt=16
Datacnt=1
index=1
Resultstr=''
Resultstrcmp=0
chkstr=''

getdir mdir
foldercreate 'Result'

fileret='03_Autotest_Result_Comm_Loopback_I2C_SPI_LPUART_USART'
sprintf2 retfilename '%s\Result\%s.txt' mdir fileret
sprintf2 delfilename 'Result\%s.txt' fileret
filedelete delfilename
fileopen frethnd retfilename 0

call tci2c
call tcspi
call tclpuart
call tcusart

fileclose frethnd
dispstr 'End of 3. Auto Test Comm Loopback I2C/SPI/LPUART/USART'
end

:tci2c
;===== START : TestCase I2C Loopback =====
dispstr 10 10
dispstr '===== START : TestCase I2C Loopback ====='
dispstr 10 

ipstr='I2C'
foldercreate ipstr

filestr='05_i2c_master_slave_intr_tx_rx_sa_0x49'
iprxstr='I2C : rx Data'
Datastr='0xa5 0x5a 0xa5 0x5a 0x5 0x7 0x9 0xa0 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0'
MaxDatacnt=16
Datacnt=1
index=1
delay=1
call dotest

filestr='06_i2c_master_slave_intr_non_maskable_tx_rx_sa_0x49'
iprxstr='I2C : rx Data'
Datastr='0xa5 0x5a 0xa5 0x5a 0x5 0x7 0x9 0xa0 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0'
MaxDatacnt=16
Datacnt=1
index=1
delay=1
call dotest

;===== END : TestCase I2C Loopback =====
dispstr 10
dispstr '===== END : TestCase I2C Loopback ====='
dispstr 10 
return

