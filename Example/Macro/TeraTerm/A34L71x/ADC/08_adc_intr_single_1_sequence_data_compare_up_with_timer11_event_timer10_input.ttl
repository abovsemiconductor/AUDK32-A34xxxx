; A. Description
;    A list of commands here configures ADC and generates single capture and comparator matched interrupt by Timer10 output signal.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. ADC
;    2. Timer1
;    3. PCU/GPIO
;    4. VREFBUF
;
; D. Default Port
;    1. ADC0    : PD7 (AN18)
;    2. Timer15 : PE1 (Output/Capture Input/External Clock Input)
;
; E. Port Connection
;    1. PE1 (Timer15 Output) ----> PD7 (AN18)
;
; For more information, read a user's manual of the target device carefully.
;
; ADC0
; 1. Channel                    : 0
;
; 2. Clock                      : [ 0 p 64 ]
;    Source                     : p (Peripheral Clock)
;    Peripheral Clock Divide    : 64
;
; 3. Config                     : [ config 0 i s 1 1 0 ]
;    Operation                  : i (Interrupt)
;    Mode                       : s (Single)
;    Base Trigger Source        : 1 (Timer1)
;    Sequence Count             : 1
;    Sampling Time              : 0
;
; 4. Seq                        : [ 0 1 5 0 18 0 ]
;    Trigger Source             : 1 (Timer1)
;    Trigger Source Number      : 5 (Timer15)
;    Sequence Number            : 0
;    Input Channel              : 18
;    Sampling Time              : 0
;
; 5. Cmp                        : [ 0 e 18 -intr e u ]
;    Comparator Enable          : e (Enable)
;    Input Channel              : 18
;    Comparator Data            : 1024
;    Interrupt Enable           : e (Enable)
;    Interrupt Trigger          : u (Input Channel Sampling Data > Comparator Data)
;
; Timer12
; 1. Channel                    : 2 (Timer12)
;
; 2. Clock                      : [ 2 m h 10 1000 ]
;    Source                     : m (MCCR : Misc Clock)
;    MCCR Source                : h (HSI : High Speed Internal Clock - 32MHz)
;    Source Divide              : 10
;    Timer1 Pre-Divide          : 1000 (MCCR Clock / 10) / 1000
;
; 3. Config                     : [ 2 i p h 1600 1600 -io o ]
;    Operation                  : i (Interrupt)
;    Mode                       : p (Period)
;    Output Port Polarity       : h (High)
;    A Data                     : 1600
;    B Data                     : 1600
;    Port In/Out (-io)          : o (Output)
;
; Timer15
; 1. Channel                    : 5 (Timer15)
;
; 2. Clock                      : [ 5 m h 10 1000 ]
;    Source                     : m (MCCR : Misc Clock)
;    MCCR Source                : h (HSI : High Speed Internal Clock - 32MHz)
;    Source Divide              : 10
;    Timer1 Pre-Divide          : 1000 (MCCR Clock / 10) / 1000
;
; 3. Config                     : [ 1 i p h 1600 1600 ]
;    Operation                  : i (Interrupt)
;    Mode                       : p (Period)
;    Output Port Polarity       : h (High)
;    A Data                     : 1600
;    B Data                     : 1600
;
; 4. Adc Trigger Config         : [ 5 e n ]
;    Enable                     : e (Enable)
;    Mode                       : n (Normal)
;
; PCU (PD7)
; 1. Port Group                : 3 (PCU Port D)
;
; 2. Port                      : [ 3 7 a 7 ]
;    Pin Number                : 7
;    Pin Mode                  : a (Alternative)
;    Alternative               : 7 (AN18)
; 
; PCU (PE1)
; 1. Port Group                : 4 (PCU Port E)
;
; 2. Port                      : [ 4 1 a 2 ]
;    Pin Number                : 1 
;    Pin Mode                  : a (Alternative)
;    Alternative               : 2 (T5IO)
; 
; PCU (PD7)
sendln 'cm pcu'
mpause 30
sendln 'port 3 7 a 7'
mpause 30

; PCU (PE1)
sendln 'port 4 1 a 2'
mpause 30

; VREFBUF
sendln 'cm vrefbuf'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'config 0 p v 64000 1'
mpause 100

; Timer12
sendln 'cm timer1'
mpause 30
sendln 'log off'
mpause 30
sendln 'uninit 2'
mpause 30
sendln 'init 2'
mpause 30
sendln 'clk 2 m h 10 1000'
mpause 30
sendln 'config 2 i p h 1600 1600'
mpause 30

; Timer15
sendln 'cm timer1'
mpause 30
sendln 'log off'
mpause 30
sendln 'uninit 5'
mpause 30
sendln 'init 5'
mpause 30
sendln 'clk 5 m h 10 1000'
mpause 30
sendln 'config 5 i p h 1600 1600'
mpause 30
sendln 'adctrg 5 e n'
mpause 30

; ADC0
sendln 'cm adc'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 p 64'
mpause 30
sendln 'config 0 i s 1 1 0'
mpause 30
sendln 'seq 0 1 5 0 18 0'
mpause 30
sendln 'cmp 0 e 18 1024 -intr e u'
mpause 30
sendln 'log on'
mpause 30

; Timer12
sendln 'cm timer1'
mpause 30
sendln 'start 2'
mpause 30

; Timer15
sendln 'start 5'
mpause 30

; ADC0
sendln 'cm adc'
mpause 30
sendln 'start 0'
