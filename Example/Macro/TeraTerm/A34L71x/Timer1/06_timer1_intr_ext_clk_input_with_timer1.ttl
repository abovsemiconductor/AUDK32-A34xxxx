; A. Description
;    A list of commands here configures timer1 and generates a periodic interrupt based on external clock source.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. Timer1
;    2. PCU/GPIO
;
; D. Default Port
;    1. Timer13 : PE14 (Output/Capture Input/External Clock Input)
;    2. Timer14 : PE15 (Output/Capture Input/External Clock Input)
;
; E. Port Connection
;    1. PE14 (Timer13 Output) ----> PE15 (Timer14 Capture Input)
;
; For more information, read a user's manual of the target device carefully.
;
; Timer14
; 1. Channel                   : 4 (Timer14)
;
; 2. Clock                     : [ 4 e f 0 ]
;    Source                    : e (External Clock Input) 
;    External Clock Input Edge : f (Falling) 
;    Timer1 Pre-Divide         : 0
;
; 3. Config                    : [ 4 i p h 2 2 -io i ]
;    Operation                 : i (Interrupt)
;    Mode                      : p (Periodic)
;    Output Port Polarity      : h (High)
;    A Data                    : 2
;    B Data                    : 2
;    Port In/Out (-io)         : i (Input)
;
; Timer13
; 1. Channel                   : 3 (Timer13)
;
; 2. Clock                     : [ 3 m h 10 1000 ]
;    Source                    : m (MCCR : Misc Clock)
;    MCCR Source               : h (HSI : High Speed Internal Clock - 32MHz)
;    Source Divide             : 10 
;    Timer1 Pre-Divide         : 1000 (MCCR Clock / 10) / 1000
;
; 3. Config                    : [ 3 i p h 3200 3200 -io o ]
;    Operation                 : i (Interrupt)
;    Mode                      : p (Period)
;    Output Port Polarity      : h (High)
;    A Data                    : 3200
;    B Data                    : 3200
;    Port In/Out (-io)         : o (Output)
;
; PCU (PE14) for Timer13
; 1. Port Group                   : 4 (PCU Port E)
;
; 2. Port                         : [ 4 14 a 2 ]
;    Pin Number                   : 14
;    Pin Mode                     : a (Alternative)
;    Alternative                  : 2 (T3IO)
;
; PCU (PE15) for Timer14
; 1. Port Group                   : 4 (PCU Port E)
;
; 2. Port                         : [ 4 15 a 2 ]
;    Pin Number                   : 15
;    Pin Mode                     : a (Alternative)
;    Alternative                  : 2 (T4IO)
;
; PCU (PE14)
sendln 'cm pcu'
mpause 30
sendln 'port 4 14 a 2'
mpause 30

; PCU (PE15)
sendln 'cm pcu'
mpause 30
sendln 'port 4 15 a 2'
mpause 30

; Timer13
sendln 'cm timer1'
mpause 30
sendln 'uninit 3'
mpause 30
sendln 'init 3'
mpause 30
sendln 'clk 3 m h 10 1000'
mpause 30
sendln 'config 3 i p h 3200 3200 -io o'
mpause 30
sendln 'log off'
mpause 30
sendln 'start 3'
mpause 30

; Timer14
sendln 'uninit 4'
mpause 30
sendln 'init 4'
mpause 30
sendln 'clk 4 e f 0'
mpause 30
sendln 'config 4 i p h 2 2 -io i'
mpause 30
sendln 'log on'
mpause 30
sendln 'start 4'
