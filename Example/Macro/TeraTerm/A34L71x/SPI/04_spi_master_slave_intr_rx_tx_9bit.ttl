; A. Description
;    A list of commands here configures SPI module and receives data via SPI.
;
; B. Preparation
;    Connecting ports with an external SPI device should be correct.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. SPI
;    2. PCU/GPIO
;
; D. Default Port
;    1. SPI0    : PA14 (Slave Select)
;               : PA15 (Serial Clock)
;               : PB0 (Master Out Slave In)
;               : PB1 (Master In Slave Out)
;    2. SPI1    : PE4 (Slave Select)
;               : PE5 (Serial Clock)
;               : PE6 (Master Out Slave In)
;               : PE7 (Master In Slave Out)
;
; E. Port Connection
;    1. PA14 (Slave Select)       <----> PE4 (Slave Select)
;    2. PA15 (Serial Clock)       <----> PE5 (Serial Clock)
;    3. PB0 (Master Out Slave In) <----> PE6 (Master Out Slave In)
;    4. PB1 (Master In Slave Out) <----> PE7 (Master In Slave Out)
;
; For more information, read a user's manual of the target device carefully.
;
; SPI0
; 1. Channel                   : 0 (SPI0)
;
; 2. Config                    : [ 0 i s 9 0 m h 5 -delay 1 1 1 ]
;    Operation                 : i (Interrupt)
;    Mode                      : s (Slave)
;    Data Length               : 9 (9bit)
;    Polarity/Phase            : 0 (Polarity : Low, Phase : Low)
;    Bit Order                 : m (MSB)
;    Slave Select Pin Polarity : h (High)
;    Baudrate                  : 5 (PCLK / (Baudrate + 1))
;    Delay Start               : 1
;    Delay Stop                : 1
;    Delay Burst               : 1
;
; 3. Rx                        : [ 0 8 ]
;    Receive Data Length       : 8
;
; SPI1
; 1. Channel                   : 1 (SPI1)
;
; 2. Config                    : [ 1 i m 9 0 m h 5 -delay 1 1 1 ]
;    Operation                 : i (Interrupt)
;    Mode                      : m (Master)
;    Data Length               : 9 (9bit)
;    Polarity/Phase            : 0 (Polarity : Low, Phase : Low)
;    Bit Order                 : m (MSB)
;    Slave Select Pin Polarity : h (High)
;    Baudrate                  : 5 (PCLK / (Baudrate + 1))
;    Delay Start               : 1
;    Delay Stop                : 1
;    Delay Burst               : 1
;
; 3. Data                      : [ 1 16 0x00 0xa5 0x01 0x5a 0x00 0xa5 0x01 0x5a 0x00 0xff 0x01 0x00 0x00 0x00 0x01 0x55 ]
;    Data Length               : 16
;    Data                      : 0x01 ... (Hexa and space (delimitor))
;
; 4. Tx                        : [ 1 8 ]
;    Transmit Data Length      : 8
;
; PCU (PAx/PBx)
; 1. Port Group                : 0 / 1 (PCU Port A/B)
;
; 2. Port                      : [ 0 14 a 1 ] [ 0 15 a 1 ] [ 1 0 a 1 ] [ 1 1 a 1 ]
;    Pin Number                : 14 / 15 / 0 / 1
;    Pin Mode                  : a (Alternative)
;    Alternative               : 1 (SS0/SCK0/MOSI0/MISO0)
;
; PCU (PEx)
; 1. Port Group                : 4 (PCU Port E)
;
; 2. Port                      : [ 4 4 a 1 ] [ 4 5 a 1 ] [ 4 6 a 1 ] [ 4 7 a 1 ]
;    Pin Number                : 4 / 5 / 6 / 7
;    Pin Mode                  : a (Alternative)
;    Alternative               : 1 (SS1/SCK1/MOSI1/MISO1)

; PCU (PAx/PBx)
sendln 'cm pcu'
mpause 30
sendln 'port 0 14 a 1'
mpause 30
sendln 'port 0 15 a 1'
mpause 30
sendln 'port 1 0 a 1'
mpause 30
sendln 'port 1 1 a 1'
mpause 30

; PCU (PEx)
sendln 'cm pcu'
mpause 30
sendln 'port 4 4 a 1'
mpause 30
sendln 'port 4 5 a 1'
mpause 30
sendln 'port 4 6 a 1'
mpause 30
sendln 'port 4 7 a 1'
mpause 30

; SPI0
sendln 'cm spi'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'config 0 i s 9 0 m h 5 -delay 1 1 1'
mpause 30
sendln 'rx 0 8'
mpause 100

; SPI1
sendln 'cm spi'
mpause 30
sendln 'uninit 1'
mpause 30
sendln 'init 1'
mpause 30
sendln 'config 1 i m 9 0 m h 5 -delay 1 1 1'
mpause 30
sendln 'data 1 16 0x00 0xa5 0x01 0x5a 0x00 0xa5 0x01 0x5a 0x00 0xff 0x01 0x00 0x00 0x00 0x01 0x55'
mpause 100
sendln 'tx 1 8'
