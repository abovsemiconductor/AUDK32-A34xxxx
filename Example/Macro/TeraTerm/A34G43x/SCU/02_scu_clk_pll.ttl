; A. Description
;    A list of commands here configures SCU CLK and generates a certain frequency of PLL Clock.
;
; B. Preparation
;    Make an environment to measure clock frequency by clock output port.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. SCUCLK
;    2. PCU/GPIO
;
; D. Default Port
;    1. PCU    : PC9 (Clock Output)
;
; For more information, read a user's manual of the target device carefully.
;
; PCU (PC9)
; 1. Port                        : [ 2 9 a 3 ]
;    Port Group Number           : 2 (C group)
;    Pin Number                  : 9
;    Pin Mode                    : a (Alternative)
;    Pin Alt Number              : 3 (Clock Output)
;
; SCUCLK
; 1. Clkout                      : [ m 0 e ]
;    Clock Source                : m (MCLK : Main Clock)
;    Clock Source Divide         : 0
;    Clock Output Enable         : e (Enable)
;
; 2. PLL                         : [ e h 8 1 15 0 0 s 10 2 ]
;    Enable                      : e (Enable)
;    Clock Source                : h (HSI : High Speed Internal Clock) ( 16MHz )
;    Clock Divide                : 4
;    PLL Pre-divide (R)          : 1
;    PLL Divide 1   (N1)         : 63
;    PLL Divide 2   (N2)         : 0
;    PLL Output Divide (P)       : 7
;    PLL VCO (Freq Doubler) (D)  : s (VCO)
;    PLL Current                 : 10
;    PLL Bias                    : 2 (none)
;
;              ( FIN * ( N1 + 1 )
;    Fout = --------------------------
;            (( R + 1 ) * ( P + 1 ))
;
; ex) pll e h 4 1 63 0 7 s 10 2 ( HSI 16MHz )
;
;            ((16000000 / 4) * ( 63 + 1 ))
;    Fout = -------------------------------,    Fout = 16MHz
;               (( 1 + 1 ) * ( 7 + 1 ))
;
; ex) pll e e 4 0 63 0 7 s 10 2 ( HSE : High Speed External Clock = 8MHz )
;
;            ((8000000 / 4) * ( 63 + 1 ))
;    Fout = -------------------------------,    Fout = 16MHz
;               (( 0 + 1 ) * ( 7 + 1 ))
;
;
; PCU (PC9)
sendln 'cm pcu'
mpause 30
sendln 'port 2 9 a 3'
mpause 30

; SCUCLK
sendln 'cm scuclk'
mpause 30
sendln 'clkout m 0 e'
mpause 30

; PLL configuration 16MHz 
sendln 'pll e h 4 1 63 0 7 s 10 2'
pause 5
sendln 'pll e e 4 1 63 0 3 s 10 2'

