; A. Description
;    A list of commands here configures ADC and generates single capture and comparator matched interrupt by DAC output signal.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
; 
; C. Prerequisite Example (abov_example_config.h)
;    1. ADC
;    2. Timer1
;    3. DAC
;    4. PCU/GPIO
;
; D. Default Port
;    1. ADC0    : PF3 (AN1/adc_ch2)
;    2. DAC1    : PA1 (DAC1O)
;
; E. Port Connection
;    1. PA1 (DAC1O) ---> PF3 (AN1/adc_ch2)
;
; For more information, read a user's manual of the target device carefully.
;
; ADC0
; 1. Channel                    : 0
;
; 2. Clock                      : [ 0 p 64 ]
;    Source                     : p (Peripheral Clock)
;    Source Divide              : 64
;
; 3. Config                     : [ config 0 i s 1 1 0 ]
;    Operation                  : i (Interrupt)
;    Mode                       : s (Single)
;    Base Trigger Source        : 1 (Timer1)
;    Sequence Count             : 1
;    Sampling Time              : 0
;
; 4. Seq                        : [ 0 1 0 0 1 0 ]
;    Trigger Source             : 1 (Timer1)
;    Trigger Source Number      : 0 (Timer10)
;    Sequence Number            : 0
;    Input Channel              : 2
;    Sampling Time              : 0
;
; 5. Cmp                        : [ 0 e 1 -intr e u ]
;    Comparator Enable          : e (Enable)
;    Input Channel              : 1
;    Comparator Data            : 100
;    Interrupt Enable           : e (Enable)
;    Interrupt Trigger          : u (Input Channel Sampling Data > Comparator Data)
;
; Timer10
; 1. Channel                    : 0 (Timer10)
;
; 2. Clock                      : [ 0 m h 10 1000 ]
;    Source                     : m (MCCR : Misc Clock)
;    MCCR Source                : h (HSI : High Speed Internal Clock - 32MHz)
;    Source Divide              : 10
;    Timer1 Pre-Divide          : 1000 (MCCR Clock / 10) / 1000
;
; 3. Config                     : [ 0 i p h 1600 1600 ]
;    Operation                  : i (Interrupt)
;    Mode                       : p (Period)
;    Output Port Polarity       : h (High)
;    A Data                     : 1600
;    B Data                     : 1600
;
; Timer11
; 1. Channel                    : 1 (Timer11)
;
; 2. Clock                      : [ 1 m h 10 1000 ]
;    Source                     : m (MCCR : Misc Clock)
;    MCCR Source                : h (HSI : High Speed Internal Clock - 32MHz)
;    Source Divide              : 10
;    Timer1 Pre-Divide          : 1000 (MCCR Clock / 10) / 1000
;
; 3. Config                     : [ 1 i p h 1600 1600 ]
;    Operation                  : i (Interrupt)
;    Mode                       : p (Period)
;    Output Port Polarity       : h (High)
;    A Data                     : 1600
;    B Data                     : 1600
;
; DAC1
; 1. Config                     : [ 1 d m i 1 -port 0x01 ]
;    Operation                  : d (Interrupt DMA)
;    Mode                       : m (Manual)
;    Reference Level            : i (Internal VDD)
;    Re-load reference          : 1 (Timer11)
;    Output Port                : 1 (DAC1)
;
; PCU (PA1)
; 1. Port Group                : 0 (PCU Port A)
;
; 2. Port                      : [ 0 1 a 3 ]
;    Pin Number                : 1
;    Pin Mode                  : a (Alternative)
;    Alternative               : 7 (DAC Output)
; 
; PCU (PF3)
; 1. Port Group                : 5 (PCU Port F)
; 2. Port                      : [ 5 3 a 3 ]
;    Pin Number                : 3
;    Pin Mode                  : a (Alternative)
;    Alternative               : 7 (AN0/AN1/adc_ch2/AN1/adc_ch2)
;
; PCU (PA1)
sendln 'cm pcu'
mpause 30
sendln 'port 0 1 a 7'
mpause 30

; PCU (PF3)
sendln 'port 5 3 a 7'
mpause 30

; Timer10
sendln 'cm timer1'
mpause 30
sendln 'log off'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 m h 10 1000'
mpause 30
sendln 'config 0 i p h 1600 1600'
mpause 30
sendln 'adctrg 0 e n'
mpause 30
sendln 'start 0'
mpause 30

; ADC0
sendln 'cm adc'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 p 64'
mpause 30
sendln 'config 0 i s 1 1 0'
mpause 30
sendln 'seq 0 1 0 0 2 0'
mpause 30
sendln 'cmp 0 e 2 1000 -intr e u'
mpause 30
sendln 'log on'
mpause 30

; Timer10
sendln 'cm timer1'
mpause 30
sendln 'start 0'
mpause 30

; DAC1
sendln 'cm dac'
mpause 30
sendln 'uninit 1'
mpause 30
sendln 'init 1'
mpause 30
sendln 'config 1 p m ign i 1 -port 0x01'
mpause 30
sendln 'start 1'
mpause 100

; ADC0
sendln 'cm adc'
mpause 30
sendln 'start 0'
mpause 30

; DAC1
sendln 'cm dac'
mpause 30

i = 1
do while i < 4096
    sprintf2 cmd "data 1 %x" i
    sendln cmd
    pause 1
    i = i * 2
loop

sprintf2 cmd "data 1 %x" 4095
sendln cmd
pause 1

sendln 'stop 1'
mpause 30
sendln 'cm adc'
mpause 30
sendln 'stop 0'
mpause 30
sendln 'cm timer1'
mpause 30
sendln 'stop 0'
