iprxstr='SPI : rx Data'
Datastr='0xa5 0x5a 0xa5 0x5a 0xff 0x10 0x1 0x55 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0'
MaxDatacnt=16
Datacnt=1
index=1
delay=1
call dotest

ipstr='SPI'
filestr='04_spi_master_slave_intr_rx_tx_9bit'
iprxstr='SPI : rx Data'
Datastr='0x0 0xa5 0x1 0x5a 0x0 0xa5 0x1 0x5a 0x0 0xff 0x1 0x0 0x0 0x0 0x1 0x55'
MaxDatacnt=16
Datacnt=1
index=1
delay=1
