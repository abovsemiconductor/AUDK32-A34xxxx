; A. Description
;    This script automatically executes I2C, UART and SPI Loopback Tera Term example scripts.
;
; B. Prerequisite Example (abov_example_config.h)
;    1. PCU/GPIO
;    2. I2C
;    3. SPI
;    4. UART
;
; C. Port Connection
;    1. I2C1/3
;     : PD4 (Serial Clock)         <---->  PF6 (Serial Clock)
;     : PD5 (Serial Data)          <---->  PF7 (Serial Data)
;    2. SPI2/3
;     : PG0 (Slave Select)         <---->  PB0 (Slave Select)
;     : PG1 (Serial Clock)         <---->  PB1 (Serial Clock)
;     : PG2 (Master Out Slave In)  <---->  PB2 (Master Out Slave In)
;     : PG3 (Master In Slave Out)  <---->  PB3 (Master In Slave Out)
;    3. UART3/12
;     : PG8 (Transmit)             <---->  PD9  (Receive)
;     : PG9 (Receive)              <---->  PD8  (Transmit)
;

timeout=600
Passstr='===== Test Result : Pass ====='#13#10
Failstr='===== Test Result : Fail ====='#13#10
Reviewstr='===== Test Result : Need Review ===='#13#10
NeedReview=0
Datastr='0xa5 0x5a 0xa5 0x5a 0x5 0x7 0x9 0xa0 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0'
MaxDatacnt=16
Datacnt=1
index=1
Resultstr=''
Resultstrcmp=0
chkstr=''

getdir mdir
foldercreate 'Result'

fileret='03_Autotest_Result_Comm_Loopback_I2C_SPI_UART'
sprintf2 retfilename '%s\Result\%s.txt' mdir fileret
sprintf2 delfilename 'Result\%s.txt' fileret
filedelete delfilename
fileopen frethnd retfilename 0

call tcuart
call tci2c
call tcspi

fileclose frethnd
dispstr 'End of 3. Auto Test Comm Loopback I2C and SPI'
end

:tcuart
;===== START : TestCase UART Loopback =====
dispstr 10 10
dispstr '===== START : TestCase UART Loopback ====='#13#10
dispstr 10 

ipstr='UART'
foldercreate ipstr

filestr='05_uart_intr_tx_rx'
iprxstr='UART : rx Data'
Datastr='0xa5 0x5a 0xa5 0x5a 0x5 0x7 0x9 0xa0 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0'
MaxDatacnt=16
Datacnt=1
index=1
delay=1
call dotest

filestr='06_uart_dma_tx_rx'
iprxstr='UART : rx Data'
Datastr='0xa5 0x5a 0xa5 0x5a 0x5 0x7 0x9 0xa0 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0'
MaxDatacnt=16
Datacnt=1
index=1
delay=1
call dotest

filestr='07_uart_intr_non_maskable_tx_maskable_rx'
iprxstr='UART : rx Data'
Datastr='0xa5 0x5a 0xa5 0x5a 0x5 0x7 0x9 0xa0 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0'
MaxDatacnt=16
Datacnt=1
index=1
delay=1
call dotest

filestr='08_uart_dma_non_maskable_tx_maskable_rx'
iprxstr='UART : rx Data'
Datastr='0xa5 0x5a 0xa5 0x5a 0x5 0x7 0x9 0xa0 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0'
MaxDatacnt=16
Datacnt=1
index=1
delay=1
call dotest

;===== END : TestCase UART Loopback =====
dispstr 10
dispstr '===== END : TestCase UART Loopback ====='#13#10
dispstr 10 
return

:tci2c
;===== START : TestCase I2C Loopback =====
dispstr 10 10
dispstr '===== START : TestCase I2C Loopback ====='#13#10
