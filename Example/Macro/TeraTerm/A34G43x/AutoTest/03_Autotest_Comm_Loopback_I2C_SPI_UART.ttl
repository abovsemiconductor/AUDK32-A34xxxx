Datacnt=1
index=1
delay=1
call dotest

ipstr='SPI'
filestr='06_spi_master_slave_intr_rx_tx_17bit'
iprxstr='SPI : rx Data'
Datastr='0x1 0x5a 0xa5 0x0 0xa5 0x5a 0x1 0xff 0x0 0x0 0x0 0xff 0x1 0x55 0xaa 0x0'
MaxDatacnt=16
Datacnt=1
index=1
delay=1
call dotest

filestr='07_spi_master_slave_dma_rx_tx_8bit'
iprxstr='SPI : rx Data'
Datastr='0xa5 0x5a 0xa5 0x5a 0xff 0x10 0x1 0x55 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0'
MaxDatacnt=16
Datacnt=1
index=1
delay=1
call dotest

ipstr='SPI'
filestr='08_spi_master_slave_dma_rx_tx_16bit'
iprxstr='SPI : rx Data'
Datastr='0x1 0x2 0x3 0x4 0x5 0x6 0xa5 0x5a 0x0 0xff 0xff 0x0 0x0 0xff 0x55 0xaa'
MaxDatacnt=16
Datacnt=1
index=1
delay=1
call dotest

filestr='09_spi_master_slave_intr_non_maskable_rx_maskable_tx_8bit'
iprxstr='SPI : rx Data'
Datastr='0xa5 0x5a 0xa5 0x5a 0xff 0x10 0x1 0x55 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0'
MaxDatacnt=16
Datacnt=1
index=1
delay=1
call dotest

filestr='10_spi_master_slave_dma_maskable_rx_non_maskable_tx_8bit'
iprxstr='SPI : rx Data'
Datastr='0xa5 0x5a 0xa5 0x5a 0xff 0x10 0x1 0x55 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0'
MaxDatacnt=16
Datacnt=1
index=1
delay=1
call dotest

;===== END : TestCase SPI Loopback =====
dispstr 10
dispstr '===== END : TestCase SPI Loopback ====='#13#10
dispstr 10 
return

:dotest
sprintf2 filename '%s\%s\%s.log' mdir ipstr filestr
sprintf2 delfilename '%s\%s.log' ipstr filestr
filedelete delfilename
sprintf2 logstr 'Test %s'#13#10 filestr
sprintf2 testfile '..\%s\%s.ttl' ipstr filestr
logopen filename 0 0
logwrite logstr
include testfile
pause delay
logclose
call decision
return

:decision
timeout=600
fileopen fhandle filename 0
if Resultstrcmp == 1 then
    call cmpstr
else
    call cmpdata
endif
fileseek fhandle 0 0
do
    filereadln fhandle line
    filewriteln frethnd line
loop while result == 0
filewriteln frethnd resultstr
filewriteln frethnd 0
filewriteln frethnd 0
fileclose fhandle
NeedReview=0
Resultstrcmp=0
resultstr=''
pause 1
return

:cmpstr
if NeedReview == 1 then
    resultstr=Reviewstr
else
    filestrseek fhandle chkstr
    if result=0 then
        resultstr=Failstr
    else 
        resultstr=Passstr
    endif
endif
return

:cmpdata
fileseek fhandle 0 0
sprintf2 parsestr '%s=([a-zA-Z0-9]+)' iprxstr
while 1
    filereadln fhandle line
    if result = 1 then
        break
    endif
    strmatch line parsestr
    if result > 0 then
        dstr = groupmatchstr1
        strinsert Resultstr index dstr
        strlen dstr
        index = index + result
        if Datacnt > MaxDataCnt - 1 then
            break
        endif
        strinsert Resultstr index ' '
        index = index + 1
        Datacnt = Datacnt + 1
    endif
endwhile
;dispstr "Result : "
;dispstr Resultstr
;dispstr 10
;dispstr "Cmp : "
;dispstr Datastr
;dispstr 10
strcompare Resultstr Datastr
if result == 0 then
    resultstr=Passstr
else
    resultstr=Failstr
endif
return
