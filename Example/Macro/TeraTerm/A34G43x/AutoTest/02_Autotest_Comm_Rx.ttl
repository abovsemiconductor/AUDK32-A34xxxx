; A. Description
;    This script automatically executes I2C, SPI, and UART RX Tera Term example scripts.
;    The 02_Autotest_Comm_Tx.ttl must be executed within 5 seconds after running this script.
;
; B. Prerequisite Example (abov_example_config.h)
;    1. PCU/GPIO
;    2. I2C
;    3. UART
;    4. SPI
;
; C. Port Connection (Testing must be conducted with two Starterkits)
;    1. I2C0
;     : PE3 (Serial Clock)         <--> PE3 (Serial Clock)
;     : PE4 (Serial Data)          <--> PE4 (Serial Data)
;    2. UART11
;     : PG6 (Transmit)             <--> PG5 (Receive)
;     : PG5 (Receive)              <--> PG6 (Transmit)
;    3. SPI10
;     : PF10 (Slave Select)        <--> PF10 (Slave Select)
;     : PF11 (Serial Clock)        <--> PF11 (Serial Clock)
;     : PF13 (Master Out Slave In) <--> PF13 (Master Out Slave In)
;     : PF12 (Master In Slave Out) <--> PF12 (Master In Slave Out)
;

timeout=600
Passstr='===== Test Result : Pass ====='#13#10
Failstr='===== Test Result : Fail ====='#13#10
Reviewstr='===== Test Result : Need Review ===='#13#10
NeedReview=0
Datastr='0xa5 0x5a 0xa5 0x5a 0x5 0x7 0x9 0xa0 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0'
MaxDatacnt=16
Datacnt=1
index=1
Resultstr=''

getdir mdir
foldercreate 'Result'

fileret='02_Autotest_Result_Comm_Rx'
sprintf2 retfilename '%s\Result\%s.txt' mdir fileret
sprintf2 delfilename 'Result\%s.txt' fileret
filedelete delfilename
fileopen frethnd retfilename 0

call tcuart
call tcspi
call tci2c

fileclose frethnd
dispstr 'End of 2. Auto Test Comm Rx'
end

;===== START : TestCase UART RX between STKs =====
dispstr 10 10
dispstr '===== START : TestCase UART RX between STKs ====='
dispstr 10 

:tcuart
ipstr='UART'
foldercreate ipstr

filestr='01_uart_intr_rx'
iprxstr='UART : rx Data'
Datastr='0xa5 0x5a 0xa5 0x5a 0x5 0x7 0x9 0xa0 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0'
MaxDatacnt=16
Datacnt=1
index=1
delay=5
call dotest

filestr='03_uart_dma_rx'
iprxstr='UART : rx Data'
Datastr='0xa5 0x5a 0xa5 0x5a 0x5 0x7 0x9 0xa0 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0'
MaxDatacnt=16
Datacnt=1
index=1
delay=5
call dotest

;===== END : TestCase UART RX between STKs =====
dispstr 10
dispstr '===== END : TestCase UART RX between STKs ====='
dispstr 10
return

:tci2c
;===== START : TestCase I2C RX between STKs =====
dispstr 10 10
dispstr '===== START : TestCase I2C RX between STKs ====='
dispstr 10

ipstr='I2C'
foldercreate ipstr

filestr='03_i2c_slave_intr_rx_sa_0x49'
iprxstr='I2C : rx Data'
Datastr='0xa5 0x5a 0xa5 0x5a 0x5 0x7 0x9 0xa0 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0'
MaxDatacnt=16
Datacnt=1
index=1
delay=10
call dotest

ipstr='I2C'
filestr='01_i2c_master_intr_rx_sa_0x49'
iprxstr='I2C : rx Data'
Datastr='0xa0 0x9 0x7 0x5 0x5a 0xa5 0x5a 0xa5 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0'
MaxDatacnt=16
Datacnt=1
index=1
delay=5
call dotest

;===== END : TestCase I2C RX between STKs =====
dispstr 10
dispstr '===== END : TestCase I2C RX between STKs ====='
dispstr 10
return

:tcspi
;===== START : TestCase SPI RX between STKs =====
dispstr 10 10
dispstr '===== START : TestCase SPI RX between STKs ====='
dispstr 10

ipstr='SPI'
foldercreate ipstr

filestr='01_spi_slave_intr_rx'
iprxstr='SPI : rx Data'
Datastr='0x1 0x2 0x3 0x4 0x5 0x6 0x7 0x9 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0'
MaxDatacnt=16
Datacnt=1
index=1
delay=5
call dotest

;===== END : TestCase SPI RX between STKs =====
dispstr 10
dispstr '===== END : TestCase SPI RX between STKs ====='
dispstr 10
return


:dotest
sprintf2 filename '%s\%s\%s.log' mdir ipstr filestr
sprintf2 delfilename '%s\%s.log' ipstr filestr
filedelete delfilename
sprintf2 logstr 'Test %s' filestr
sprintf2 testfile '..\%s\%s.ttl' ipstr filestr
logopen filename 0 0
logwrite logstr
include testfile
pause delay
logclose
call decision
return

:decision
timeout=600
fileopen fhandle filename 0
call cmpdata
fileseek fhandle 0 0
do
    filereadln fhandle line
    filewriteln frethnd line
loop while result == 0
filewriteln frethnd resultstr
filewriteln frethnd 0
filewriteln frethnd 0
fileclose fhandle
NeedReview=0
resultstr=''
pause 1
return

:cmpdata
fileseek fhandle 0 0
sprintf2 parsestr '%s=([a-zA-Z0-9]+)' iprxstr
while 1
    filereadln fhandle line
    if result = 1 then
        break
    endif
    strmatch line parsestr
    if result > 0 then
        dstr = groupmatchstr1
        strinsert Resultstr index dstr
        strlen dstr
        index = index + result
        if Datacnt > MaxDataCnt - 1 then
            break
        endif
        strinsert Resultstr index ' '
        index = index + 1
        Datacnt = Datacnt + 1
    endif
endwhile
;dispstr "Result : "
;dispstr Resultstr
;dispstr 10
;dispstr "Cmp : "
;dispstr Datastr
;dispstr 10
strcompare Resultstr Datastr
if result == 0 then
    resultstr=Passstr
else
    resultstr=Failstr
endif
return
