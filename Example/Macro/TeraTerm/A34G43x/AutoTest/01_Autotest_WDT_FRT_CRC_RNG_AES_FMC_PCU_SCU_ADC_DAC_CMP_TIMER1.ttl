; A. Description
;    This script automatically executes WDT, FRT, CRC, RNG, AES, FMC, some of Timer1, ADC, DAC, CMP, some of PCU, and SCU Tera Term example scripts.
;
; B. Prerequisite Example (abov_example_config.h)
;    1. PCU/GPIO
;    2. WDT
;    3. FRT
;    4. FMC
;    5. SCU
;    6. PWM
;    7. Timer1
;    8. ADC
;    9. DAC
;    10. CMP
;    11. CRC
;    12. RNG
;    13. AES
;
; C. Port Connection
;    1. ADC
;       : PA6 (Timer12 Output) ----> PA8 (AN8)
;       : PA1 (DAC1O)          ----> PF3 (AN1)
;    2. CMP
;       : PA5 (Timer11 Output) ----> PA4 (CP0A0)
;       : PA0 (DAC0O)          ----> PA7 (CP0B)
;    3. PCU
;       : PE8 (Timer17 Output) ----> PE9 (Input)
;       : PF11 (Output)        ----> PF10 (Input)
;    4. Timer1
;       : PB4 (Timer18 Output) ----> PB5 (Timer19 Capture Input)

timeout=3000
Passstr='===== Test Result : Pass ====='#13#10
Failstr='===== Test Result : Fail ====='#13#10
Reviewstr='===== Test Result : Need Review ===='#13#10
NeedReview=0

getdir mdir
foldercreate 'Result'

fileret='01_Autotest_Result_WDT_FRT_CRC_RNG_AES_FMC_PCU_SCU_ADC_DAC_CMP_TIMER1'
sprintf2 retfilename '%s\Result\%s.txt' mdir fileret
sprintf2 delfilename 'Result\%s.txt' fileret
filedelete delfilename
fileopen frethnd retfilename 0

call tcwdt
call tcfrt
call tccrc
call tcrng
call tcaes
call tcpcu
call tcscu
call tcpwm
call tctimer1
call tcadc
call tccmp
call tcfmc

fileclose frethnd
dispstr 'End of 1. Auto Test WDT/FRT/CRC/FMC/PCU/SCU/ADC/Timer1'
dispstr 10
dispstr 'Must process the remained PCU/SCU TC.'
end

:tcwdt
; ===== START : TestCase WDT =====
dispstr 10 10
dispstr '===== START : TestCase WDT ====='
dispstr 10

ipstr='WDT'
foldercreate ipstr

filestr='01_wdt_intr_maskable_underflow'
chkstr='WDT : (0) U evt fired'
delay=5
call dotest
sendln 'stop 0'
pause 1

filestr='02_wdt_intr_non_maskable_underflow'
chkstr='WDT : (0) U evt fired'
delay=5
call dotest
sendln 'stop 0'
pause 1

filestr='03_wdt_intr_reset'
chkstr='= Executable module list ='
delay=10
call dotest

; ===== END : TestCase WDT =====
dispstr 10
dispstr '===== END : TestCase WDT ====='
dispstr 10
return

